# ============================================================================
# AutoGestão - Variáveis de ambiente
# Copie este arquivo para .env.local (dev) ou configure no Vercel (prod).
# ============================================================================

# --- Banco de dados (Neon PostgreSQL) --------------------------------------
# URL com pool (usada pela app em runtime serverless)
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/autogestao?sslmode=require&pgbouncer=true"
# URL direta (usada pelo Prisma para migrations)
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/autogestao?sslmode=require"

# --- Autenticação (Auth.js v5) ---------------------------------------------
# Gere com: openssl rand -base64 32
AUTH_SECRET=""
# Deixe vazio em dev; em produção use a URL pública (https://app.autogestao.com)
AUTH_URL=""

# --- Armazenamento de arquivos (Supabase Storage) ----------------------------
# Crie um projeto em supabase.com, vá em Settings > API
SUPABASE_URL="https://xxxxxxxxxxx.supabase.co"
# Use a Service Role Key (nunca exponha no frontend)
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
# Crie um bucket público chamado "veiculos-fotos" em Storage > New bucket

# --- Armazenamento legado (Vercel Blob) -------------------------------------
BLOB_READ_WRITE_TOKEN=""

# --- Assinatura eletrônica (DocuSign - Fase 2) ------------------------------
DOCUSIGN_INTEGRATION_KEY=""
DOCUSIGN_USER_ID=""
DOCUSIGN_ACCOUNT_ID=""
DOCUSIGN_RSA_PRIVATE_KEY=""
DOCUSIGN_BASE_URL="https://demo.docusign.net/restapi"

# --- E-mail transacional (Resend) -------------------------------------------
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@autogestao.com"
# E-mail interno que recebe alertas de novos leads/pedidos de upgrade de plano
PLATFORM_ALERT_EMAIL="edgar+volante7@skalena.com"

# --- WhatsApp (Evolution API - Fase 3) --------------------------------------
WHATSAPP_API_URL=""
WHATSAPP_API_KEY=""
WHATSAPP_INSTANCE=""

# --- Fila de jobs (Upstash QStash - Fase 3) ---------------------------------
QSTASH_TOKEN=""
QSTASH_CURRENT_SIGNING_KEY=""
QSTASH_NEXT_SIGNING_KEY=""

# --- Segurança de segredos armazenados em IntegracaoConfig ------------------
# Chave AES-256 (32 bytes em base64) para criptografar credenciais por tenant
INTEGRATION_ENCRYPTION_KEY=""

# --- App -------------------------------------------------------------------
# Em prod: URL pública do Vercel ou domínio próprio
NEXT_PUBLIC_APP_URL="https://trevisani-platform.vercel.app"
NEXT_PUBLIC_APP_NAME="AutoGestão"

# --- Website / Vitrine por tenant ------------------------------------------
# Em dev:  localhost:3000   → acessar como demo.localhost:3000
# Em prod: volante7.com.br     → acessar como demo.volante7.com.br
# Enquanto não tiver domínio próprio, use o domínio Vercel (sem suporte a subdomínio):
NEXT_PUBLIC_ROOT_DOMAIN="trevisani-platform.vercel.app"
