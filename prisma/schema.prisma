// ─── Módulo WhatsApp (Evolution API) ─────────────────────────────────────────

enum StatusWpp {
  DESCONECTADO
  AGUARDANDO_QR
  CONECTADO
  ERRO
}

model IntegracaoWhatsApp {
  id              String    @id @default(cuid())
  tenantId        String    @unique
  instanceName    String    @unique // = `loja-{tenantId}` — estável mesmo se o slug da loja mudar
  status          StatusWpp @default(DESCONECTADO)
  numeroConectado String?
  qrCode          String?   // base64 do QR atual (temporário)
  qrExpiresAt     DateTime?
  webhookSecret   String    // token para validar chamadas da Evolution API
  criarLeadAuto   Boolean   @default(true) // cria ClienteFinal automaticamente ao receber mensagem de número desconhecido
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversas ConversaWpp[]

  @@map("integracao_whatsapp")
}

model ConversaWpp {
  id             String    @id @default(cuid())
  integracaoId   String
  remoteJid      String    // numero@s.whatsapp.net
  nomeContato    String?
  clienteId      String?   // vínculo ao ClienteFinal se número cadastrado
  totalNaoLidas  Int       @default(0)
  ultimaMensagem DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  integracao IntegracaoWhatsApp @relation(fields: [integracaoId], references: [id], onDelete: Cascade)
  cliente    ClienteFinal?      @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  mensagens  MensagemWpp[]

  @@unique([integracaoId, remoteJid])
  @@index([integracaoId, ultimaMensagem])
  @@map("conversa_wpp")
}

model MensagemWpp {
  id          String   @id @default(cuid())
  conversaId  String
  messageId   String   // ID da Evolution API (deduplicação)
  fromMe      Boolean
  tipo        String   @default("text") // text | image | audio | document | sticker
  corpo       String?  // texto da mensagem
  mediaUrl    String?  // URL pública da mídia
  mimetype    String?
  lida        Boolean  @default(false)
  timestamp   DateTime
  createdAt   DateTime @default(now())

  conversa ConversaWpp @relation(fields: [conversaId], references: [id], onDelete: Cascade)

  @@unique([conversaId, messageId])
  @@index([conversaId, timestamp])
  @@map("mensagem_wpp")
}

// ─── Módulo de Leilão ─────────────────────────────────────────────────────────

enum StatusLeilao {
  AGENDADO
  ATIVO
  ENCERRADO
  CANCELADO
}

model Leilao {
  id              String       @id @default(cuid())
  tenantId        String
  veiculoId       String?
  titulo          String
  descricao       String?
  precoInicial    Int          // centavos
  precoAtual      Int          // centavos — atualizado a cada lance
  incrementoMin   Int          @default(0)  // incremento mínimo por lance (centavos)
  dataInicio      DateTime
  dataFim         DateTime
  status          StatusLeilao @default(AGENDADO)
  vencedorId      String?      // clienteId do ganhador
  valorFinal      Int?         // valor do lance vencedor (centavos)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  veiculo   Veiculo?       @relation(fields: [veiculoId], references: [id], onDelete: SetNull)
  vencedor  ClienteFinal?  @relation(name: "LeilaoVencedor", fields: [vencedorId], references: [id], onDelete: SetNull)
  lances    Lance[]

  @@index([tenantId, status])
  @@index([dataFim, status])
}

model Lance {
  id            String   @id @default(cuid())
  leilaoId      String
  clienteId     String
  valorCentavos Int
  createdAt     DateTime @default(now())

  leilao  Leilao       @relation(fields: [leilaoId], references: [id], onDelete: Cascade)
  cliente ClienteFinal @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([leilaoId, createdAt])
}
