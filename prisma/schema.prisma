// AutoGestão - Schema Prisma
// Estratégia multi-tenant: schema único compartilhado + coluna `tenantId`
// em toda entidade de negócio. RLS é aplicada via migration SQL adicional.
// -----------------------------------------------------------------------------

generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =========================================================================
// ENUMS
// =========================================================================

enum EscopoUsuario {
  STAFF       // Operador ou admin do tenant
  FORNECEDOR  // Portal do fornecedor
  CLIENTE     // Portal do cliente final
  PLATAFORMA  // Super Admin (sem tenantId)
}

enum OtpProposito {
  LOGIN
  RESET_SENHA
}

enum StatusTenant {
  ATIVO
  SUSPENSO
  TRIAL
  CANCELADO
}

enum StatusAssinaturaPlataforma {
  ATIVA
  INADIMPLENTE
  CANCELADA
  TRIAL
}

enum StatusVeiculo {
  NEGOCIANDO
  DISPONIVEL
  RESERVADO
  VENDIDO
  EM_PREPARACAO
  BAIXADO
}

enum CombustivelVeiculo {
  GASOLINA
  ETANOL
  FLEX
  DIESEL
  GNV
  HIBRIDO
  ELETRICO
}

enum CambioVeiculo {
  MANUAL
  AUTOMATICO
  AUTOMATIZADO
  CVT
}

enum OrigemVeiculo {
  COMPRA
  CONSIGNACAO
  TROCA
}

enum StatusOferta {
  ENVIADA
  EM_ANALISE
  ACEITA
  RECUSADA
  CONVERTIDA
  CANCELADA
}

enum StatusCompra {
  RASCUNHO
  AGUARDANDO_ASSINATURA
  CONCLUIDA
  CANCELADA
}

enum StatusVenda {
  RASCUNHO
  PROPOSTA_ENVIADA
  RESERVADA
  AGUARDANDO_ASSINATURA
  CONCLUIDA
  CANCELADA
}

enum TipoPessoa {
  PF
  PJ
}

enum StatusDespesa {
  ABERTA
  PAGA
  CANCELADA
}

enum TipoMovimento {
  ENTRADA
  SAIDA
}

enum StatusMovimentacao {
  PENDENTE    // a receber / a pagar
  PAGO        // liquidado
  CANCELADO
}

enum TipoDocumentoVeiculo {
  NOTA_FISCAL
  LAUDO_VISTORIA
  CERTIFICADO_PROPRIEDADE
  CONTRATO
  FOTO_DOCUMENTO  // foto de documento (ex: CRLV, CNH)
  OUTRO
}

enum StatusFotoVeiculo {
  BATIDO        // foto tirada no recebimento com danos
  EM_REPARO     // foto durante a preparação/reparo
  PRONTO_VENDA  // foto final para vitrine
}

enum CategoriaFotoVeiculo {
  EXTERNA       // fotos externas do veículo (vitrine)
  INTERNA       // fotos internas / condição na chegada (avarias)
  MOTOR         // fotos do compartimento do motor
  DOCUMENTACAO  // fotos de documentos (CRLV, NF, etc.)
}

enum StatusChecklist {
  PENDENTE   // criado mas não totalmente preenchido
  CONCLUIDO  // todos os itens avaliados e marcado como concluído
}

enum CategoriaItemChecklist {
  LATARIA
  MOTOR
  PNEUS
  ESTOFADO
}

enum FormaPagamento {
  PIX
  BOLETO
  CARTAO
  TRANSFERENCIA
  FINANCIAMENTO
  DINHEIRO
  OUTRO
}

enum StatusParcela {
  ABERTA
  PAGA
  ATRASADA
  CANCELADA
}

enum StatusAssinaturaDoc {
  RASCUNHO
  ENVIADO
  PARCIALMENTE_ASSINADO
  CONCLUIDO
  CANCELADO
  EXPIRADO
}

enum ProvedorAssinatura {
  DOCUSIGN
  ZAPSIGN
  CLICKSIGN
  D4SIGN
}

enum ProvedorEmail {
  RESEND
  SMTP
}

enum ProvedorWhatsapp {
  EVOLUTION
  CLOUD_API
}

enum TipoIntegracao {
  ASSINATURA
  EMAIL
  WHATSAPP
  ARMAZENAMENTO
  CONSULTA_VEICULAR
}

enum TemaWebsite {
  CLASSICO
  MODERNO
  MINIMAL
}

enum FonteWebsite {
  INTER
  POPPINS
  ROBOTO
  LATO
  MONTSERRAT
}

// =========================================================================
// PLATAFORMA (sem tenantId)
// =========================================================================

model Plataforma {
  id         String   @id @default(cuid())
  nome       String
  dominio    String?
  configJson Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("plataforma")
}

model Plano {
  id                     String   @id @default(cuid())
  nome                   String   @unique
  slug                   String   @unique
  descricao              String?
  precoMensalCentavos    Int      @default(0)
  precoAnualCentavos     Int      @default(0)
  // Limites operacionais
  limiteUsuarios         Int      @default(5)
  limiteVeiculos         Int      @default(50)    // -1 = ilimitado
  limiteStorageMB        Int      @default(1024)  // -1 = ilimitado
  limitePlacasMes        Int      @default(100)   // -1 = ilimitado
  limiteCnpjsMes         Int      @default(50)    // -1 = ilimitado
  limiteClientesMes      Int      @default(200)   // -1 = ilimitado
  // Feature flags e integrações
  limiteIntegracoesJson  Json?    // { assinatura: true, whatsapp: false, ... }
  featuresJson           Json?    // feature flags livres
  ativo                  Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  assinaturas AssinaturaPlataforma[]
  tenants     Tenant[]

  @@map("plano")
}

// ─── Eventos cobráveis (configuráveis pelo Super Admin) ──────────────────────

model TipoEvento {
  id            String   @id @default(cuid())
  slug          String   @unique  // ex: "consulta_placa", "consulta_cnpj"
  nome          String
  descricao     String?
  precoCentavos Int      @default(0)   // preço unitário quando fora do plano
  ativo         Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  registros RegistroEvento[]

  @@map("tipo_evento")
}

model RegistroEvento {
  id            String   @id @default(cuid())
  tenantId      String
  tipoEventoId  String
  valorCentavos Int      @default(0)  // valor cobrado (0 = incluso no plano)
  metadataJson  Json?                 // ex: { placa: "ABC1234" }
  createdAt     DateTime @default(now())

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tipoEvento TipoEvento @relation(fields: [tipoEventoId], references: [id])

  @@index([tenantId, tipoEventoId])
  @@index([tenantId, createdAt])
  @@map("registro_evento")
}

// Cache compartilhado de consultas públicas (Receita Federal / CEP).
// Dados públicos: sem tenantId de propósito — todos os tenants aproveitam.

model CnpjCache {
  cnpj         String   @id // 14 dígitos
  payload      Json        // retorno bruto da OpenCNPJ
  consultadoEm DateTime @updatedAt

  @@map("cnpj_cache")
}

model CepCache {
  cep          String   @id // 8 dígitos
  logradouro   String?
  bairro       String?
  cidade       String?
  uf           String?
  consultadoEm DateTime @updatedAt

  @@map("cep_cache")
}

// Cache de consulta de placas via wdapi2.com.br.
// Compartilhado entre todos os tenants (dados públicos do DENATRAN).
// TTL de 60 dias — revalidado automaticamente na próxima consulta.
model PlacaCache {
  placa        String   @id // formato normalizado: sem hífen, uppercase (ex: ABC1D23)
  payload      Json     // resposta bruta da API (inclui campo "extra" quando disponível)
  consultadoEm DateTime @updatedAt

  @@map("placa_cache")
}

model AssinaturaPlataforma {
  id             String                     @id @default(cuid())
  tenantId       String                     @unique
  planoId        String
  status         StatusAssinaturaPlataforma @default(TRIAL)
  cicloDias      Int                        @default(30)
  inicioAtual    DateTime                   @default(now())
  fimAtual       DateTime?
  canceladoEm    DateTime?
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plano  Plano  @relation(fields: [planoId], references: [id])

  @@index([status])
  @@map("assinatura_plataforma")
}

// =========================================================================
// TENANT (raiz da isolação)
// =========================================================================

model Tenant {
  id              String       @id @default(cuid())
  nome            String
  razaoSocial     String?
  cnpj            String?      @unique
  slug            String       @unique
  dominio         String?      @unique
  logoUrl         String?
  status          StatusTenant @default(TRIAL)
  configJson      Json?
  planoId         String?
  storageUsadoBytes  Int        @default(0)  // soma de todos os uploads em bytes
  descontoPercent    Int        @default(0)  // 0-100, desconto concedido pelo super admin
  leilaoHabilitado      Boolean    @default(false) // feature flag: módulo de leilão
  whatsappHabilitado    Boolean    @default(false) // feature flag: módulo WhatsApp
  // Preenchido quando o lojista solicita upgrade de plano (pagamento ainda manual).
  // Usado para alertar o Super Admin em /admin/tenants e evitar notificações duplicadas.
  upgradeSolicitadoEm DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  plano                Plano?                @relation(fields: [planoId], references: [id])
  assinaturaPlataforma AssinaturaPlataforma?

  usuarios             Usuario[]
  papeis               Papel[]
  fornecedores         Fornecedor[]
  clientesFinais       ClienteFinal[]
  veiculos             Veiculo[]
  ofertas              OfertaVeiculo[]
  pacotesOferta        PacoteOferta[]
  compras              Compra[]
  vendas               Venda[]
  despesas             Despesa[]
  pagamentos           Pagamento[]
  categoriasFinanceira CategoriaFinanceira[]
  contasBancarias      ContaBancaria[]
  movimentacoes        Movimentacao[]
  modelosDocumento     ModeloDocumento[]
  registrosEvento      RegistroEvento[]
  configuracaoFiscal   ConfiguracaoFiscal?
  orcamentos           OrcamentoMensal[]
  documentos           Documento[]
  fluxosAssinatura     FluxoAssinatura[]
  leiloes              Leilao[]
  integracaoWhatsApp   IntegracaoWhatsApp?
  integracoesConfig    IntegracaoConfig[]
  emailLogs            EmailLog[]
  mensagensWhatsapp    MensagemWhatsapp[]
  notificacoes         Notificacao[]
  auditLogs            AuditLog[]
  websiteConfig        WebsiteConfig?

  @@index([status])
  @@map("tenant")
}

// =========================================================================
// RBAC + USUÁRIOS
// =========================================================================

model Usuario {
  id            String        @id @default(cuid())
  tenantId      String?       // null = Super Admin
  escopo        EscopoUsuario
  nome          String
  email         String
  senhaHash     String?       // null se o login for por provedor externo
  emailVerified DateTime?
  imageUrl      String?
  fornecedorId  String?       @unique
  clienteId     String?       @unique
  ativo         Boolean       @default(true)
  ultimoLoginEm DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  tenant       Tenant?         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fornecedor   Fornecedor?     @relation(fields: [fornecedorId], references: [id])
  clienteFinal ClienteFinal?   @relation(fields: [clienteId], references: [id])
  papeis       UsuarioPapel[]
  accounts     Account[]
  sessions     Session[]
  auditLogs    AuditLog[]
  otpCodes     OtpCode[]

  @@unique([tenantId, email])
  @@index([email])
  @@map("usuario")
}

model Papel {
  id          String   @id @default(cuid())
  tenantId    String
  nome        String
  slug        String
  descricao   String?
  sistemico   Boolean  @default(false) // não pode ser removido pelo Admin do tenant
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  permissoes  PapelPermissao[]
  usuarios    UsuarioPapel[]

  @@unique([tenantId, slug])
  @@map("papel")
}

model Permissao {
  id        String   @id @default(cuid())
  slug      String   @unique // ex.: "veiculo.criar", "venda.aprovar"
  modulo    String
  acao      String
  descricao String?
  createdAt DateTime @default(now())

  papeis PapelPermissao[]

  @@map("permissao")
}

model PapelPermissao {
  papelId     String
  permissaoId String

  papel     Papel     @relation(fields: [papelId], references: [id], onDelete: Cascade)
  permissao Permissao @relation(fields: [permissaoId], references: [id], onDelete: Cascade)

  @@id([papelId, permissaoId])
  @@map("papel_permissao")
}

model UsuarioPapel {
  usuarioId String
  papelId   String
  createdAt DateTime @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  papel   Papel   @relation(fields: [papelId], references: [id], onDelete: Cascade)

  @@id([usuarioId, papelId])
  @@map("usuario_papel")
}

// =========================================================================
// Auth.js (NextAuth) - contas e sessões
// =========================================================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user Usuario @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("account")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user Usuario @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_token")
}

model OtpCode {
  id         String       @id @default(cuid())
  usuarioId  String
  codigoHash String
  proposito  OtpProposito
  expires    DateTime
  tentativas Int          @default(0)
  usadoEm    DateTime?
  createdAt  DateTime     @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId, proposito, expires])
  @@map("otp_code")
}

// =========================================================================
// FORNECEDORES E CLIENTES FINAIS
// =========================================================================

model Fornecedor {
  id           String     @id @default(cuid())
  tenantId     String
  tipoPessoa   TipoPessoa @default(PJ)
  nome         String                  // nome completo (PF) ou nome fantasia (PJ)
  razaoSocial  String?                 // razão social (PJ)
  documento    String                  // CPF ou CNPJ (somente dígitos)
  email        String?
  telefone     String?
  // Endereço (auto-preenchido via ViaCEP ou consulta CNPJ)
  cep          String?
  logradouro   String?
  numero       String?
  complemento  String?
  bairro       String?
  cidade       String?
  estado       String?                 // UF (2 letras)
  // Dados da Receita Federal (apenas PJ, via OpenCNPJ)
  situacaoCadastral    String?
  naturezaJuridica     String?
  porteEmpresa         String?
  dataInicioAtividade  DateTime?
  dadosCnpjJson        Json?           // payload bruto da última consulta (auditoria)
  observacoes  String?
  ativo        Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  tenant        Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  usuario       Usuario?
  cnaes         FornecedorCnae[]
  ofertas       OfertaVeiculo[]
  pacotes       PacoteOferta[]
  compras       Compra[]
  movimentacoes Movimentacao[]

  @@unique([tenantId, documento])
  @@index([tenantId, nome])
  @@map("fornecedor")
}

// CNAEs do fornecedor PJ (principal + secundários), vindos da consulta CNPJ.
model FornecedorCnae {
  id           String  @id @default(cuid())
  fornecedorId String
  codigo       String
  descricao    String
  principal    Boolean @default(false)

  fornecedor Fornecedor @relation(fields: [fornecedorId], references: [id], onDelete: Cascade)

  @@unique([fornecedorId, codigo])
  @@map("fornecedor_cnae")
}

model ClienteFinal {
  id              String     @id @default(cuid())
  tenantId        String
  tipoPessoa      TipoPessoa @default(PF)
  nome            String
  // CPF (PF, 11 dígitos sem máscara) ou CNPJ (PJ, 14 dígitos)
  documento       String
  email           String?
  // celular / WhatsApp (somente dígitos, ex: "11999990000")
  telefone        String?
  // Aniversário (apenas dia e mês, para ações de marketing — somente PF)
  aniversarioDia  Int?
  aniversarioMes  Int?
  // Tags de perfil (ex: ["suv","caminhonete"]) para segmentação e filtros
  tags            String[]
  // Endereço estruturado (preenchido via ViaCEP ou CNPJ API)
  cep             String?
  logradouro      String?
  numero          String?
  complemento     String?
  bairro          String?
  cidade          String?
  uf              String?
  observacoes     String?    @db.Text
  consenteLgpd    Boolean    @default(false)
  ativo           Boolean    @default(true)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  tenant        Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  usuario       Usuario?
  vendas        Venda[]
  documentos    DocumentoCliente[]
  movimentacoes Movimentacao[]
  lances        Lance[]
  leioesVencidos Leilao[]         @relation("LeilaoVencedor")
  conversasWpp   ConversaWpp[]

  @@unique([tenantId, documento])
  @@index([tenantId, nome])
  @@index([tenantId, ativo])
  @@map("cliente_final")
}

model DocumentoCliente {
  id           String   @id @default(cuid())
  clienteId    String
  nome         String
  url          String
  storagePath  String
  mimeType     String
  tamanhoBytes Int      @default(0)
  descricao    String?  @db.Text
  createdAt    DateTime @default(now())

  cliente ClienteFinal @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([clienteId])
  @@map("documento_cliente")
}

// =========================================================================
// VEÍCULOS E OFERTAS
// =========================================================================

model Veiculo {
  id                  String              @id @default(cuid())
  tenantId            String
  slug                String              // amigável p/ URL pública (ex: honda-civic-2020), único por loja
  placa               String?
  renavam             String?
  chassi              String?
  marca               String
  modelo              String
  versao              String?
  anoFabricacao       Int
  anoModelo           Int
  cor                 String?
  combustivel         CombustivelVeiculo?
  cambio              CambioVeiculo?
  kmAtual             Int?
  categoria           String?
  situacaoDocumental  String?
  origem              OrigemVeiculo       @default(COMPRA)
  precoCustoCentavos  Int                 @default(0)
  precoVendaCentavos  Int                 @default(0)
  status              StatusVeiculo       @default(EM_PREPARACAO)
  fornecedorId        String?
  observacoes         String?

  // ─ Detalhes técnicos ──────────────────────────────────────────────────────
  motor               String?   // cilindrada normalizada (ex: "1.6", "2.0T")
  portas              Int?      // número de portas
  ufRegistro          String?   // UF de emplacamento (da API)

  // ─ CRV / Documentação ────────────────────────────────────────────────────
  tipoCrv             String?   // tipo do CRV (ex: "Definitivo")
  numeroCrv           String?   // número do CRV

  // ─ Condições / Flags ──────────────────────────────────────────────────────
  chassiRemarcado     Boolean              @default(false)
  blindado            Boolean              @default(false)
  leilao              Boolean              @default(false)
  sinistro            Boolean              @default(false)
  manualProprietario  Boolean              @default(false)
  chaveReserva        Boolean              @default(false)

  // ─ Proprietário anterior ──────────────────────────────────────────────────
  proprietarioNome    String?
  proprietarioDoc     String?   // CPF/CNPJ do proprietário no CRV

  // Data em que o veículo ficou disponível (auto-preenchida ao mover para DISPONIVEL)
  dataChegada         DateTime?

  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  tenant        Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fotos         FotoVeiculo[]
  documentos    DocumentoVeiculo[]
  ofertas       OfertaVeiculo[]
  itensCompra   ItemCompra[]
  itensVenda    ItemVenda[]
  checklists    ChecklistVeiculo[]
  movimentacoes Movimentacao[]
  leiloes       Leilao[]

  @@unique([tenantId, chassi])
  @@unique([tenantId, placa])
  @@unique([tenantId, slug])
  @@index([tenantId, status])
  @@index([tenantId, marca, modelo])
  @@map("veiculo")
}

model FotoVeiculo {
  id          String            @id @default(cuid())
  veiculoId   String
  url         String            // URL pública no Supabase Storage
  storagePath String            // path interno para exclusão no bucket
  legenda     String?
  status      StatusFotoVeiculo    @default(PRONTO_VENDA)
  categoria   CategoriaFotoVeiculo @default(EXTERNA)
  destaque    Boolean              @default(false)
  ordem       Int                  @default(0)
  createdAt   DateTime             @default(now())

  veiculo Veiculo @relation(fields: [veiculoId], references: [id], onDelete: Cascade)

  @@index([veiculoId, ordem])
  @@map("foto_veiculo")
}

model DocumentoVeiculo {
  id           String                 @id @default(cuid())
  veiculoId    String
  nome         String
  url          String
  storagePath  String
  mimeType     String
  tamanhoBytes Int                    @default(0)
  tipo         TipoDocumentoVeiculo   @default(OUTRO)
  anotacao     String?                @db.Text
  tags         String[]               @default([])
  createdAt    DateTime               @default(now())

  veiculo Veiculo @relation(fields: [veiculoId], references: [id], onDelete: Cascade)

  @@index([veiculoId])
  @@map("documento_veiculo")
}

// ─── Checklists de inspeção ───────────────────────────────────────────────────

model ChecklistVeiculo {
  id          String          @id @default(cuid())
  veiculoId   String
  titulo      String          // ex: "Inspeção #1"
  status      StatusChecklist @default(PENDENTE)
  observacoes String?         @db.Text
  realizadoEm DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  veiculo Veiculo         @relation(fields: [veiculoId], references: [id], onDelete: Cascade)
  itens   ItemChecklist[]

  @@index([veiculoId])
  @@map("checklist_veiculo")
}

model ItemChecklist {
  id              String                 @id @default(cuid())
  checklistId     String
  categoria       CategoriaItemChecklist
  // null = não avaliado, true = ok, false = com problema
  ok              Boolean?
  observacao      String?                @db.Text
  dataVerificacao DateTime?

  checklist ChecklistVeiculo    @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  fotos     FotoItemChecklist[]

  @@index([checklistId])
  @@map("item_checklist")
}

model FotoItemChecklist {
  id          String   @id @default(cuid())
  itemId      String
  url         String
  storagePath String
  createdAt   DateTime @default(now())

  item ItemChecklist @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("foto_item_checklist")
}

model OfertaVeiculo {
  id                    String       @id @default(cuid())
  tenantId              String
  fornecedorId          String
  veiculoId             String?      // preenchido após conversão em estoque
  pacoteId              String?
  marca                 String
  modelo                String
  anoModelo             Int
  kmAtual               Int?
  precoPretendidoCentavos Int
  observacoes           String?
  status                StatusOferta @default(ENVIADA)
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  tenant     Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fornecedor Fornecedor    @relation(fields: [fornecedorId], references: [id])
  veiculo    Veiculo?      @relation(fields: [veiculoId], references: [id])
  pacote     PacoteOferta? @relation(fields: [pacoteId], references: [id])

  @@index([tenantId, status])
  @@map("oferta_veiculo")
}

model PacoteOferta {
  id           String       @id @default(cuid())
  tenantId     String
  fornecedorId String
  nome         String
  observacoes  String?
  status       StatusOferta @default(ENVIADA)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  tenant     Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fornecedor Fornecedor      @relation(fields: [fornecedorId], references: [id])
  itens      OfertaVeiculo[]

  @@index([tenantId, status])
  @@map("pacote_oferta")
}

// =========================================================================
// COMPRAS E VENDAS
// =========================================================================

model Compra {
  id                    String       @id @default(cuid())
  tenantId              String
  fornecedorId          String
  numero                Int          // sequencial por tenant
  dataOperacao          DateTime     @default(now())
  valorTotalCentavos    Int          @default(0)
  observacoes           String?
  status                StatusCompra @default(RASCUNHO)
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fornecedor    Fornecedor     @relation(fields: [fornecedorId], references: [id])
  itens         ItemCompra[]
  pagamentos    Pagamento[]
  documentos    Documento[]
  movimentacoes Movimentacao[]

  @@unique([tenantId, numero])
  @@index([tenantId, status])
  @@map("compra")
}

model ItemCompra {
  id                 String @id @default(cuid())
  compraId           String
  veiculoId          String
  valorCentavos      Int
  observacoes        String?

  compra  Compra  @relation(fields: [compraId], references: [id], onDelete: Cascade)
  veiculo Veiculo @relation(fields: [veiculoId], references: [id])

  @@map("item_compra")
}

model Venda {
  id                    String      @id @default(cuid())
  tenantId              String
  clienteId             String
  numero                Int          // sequencial por tenant
  dataOperacao          DateTime     @default(now())
  valorTotalCentavos    Int          @default(0)
  descontoCentavos      Int          @default(0)
  entradaCentavos       Int          @default(0)
  observacoes           String?
  status                StatusVenda @default(RASCUNHO)
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cliente       ClienteFinal   @relation(fields: [clienteId], references: [id])
  itens         ItemVenda[]
  pagamentos    Pagamento[]
  documentos    Documento[]
  movimentacoes Movimentacao[]

  @@unique([tenantId, numero])
  @@index([tenantId, status])
  @@map("venda")
}

model ItemVenda {
  id            String @id @default(cuid())
  vendaId       String
  veiculoId     String
  valorCentavos Int
  observacoes   String?

  venda   Venda   @relation(fields: [vendaId], references: [id], onDelete: Cascade)
  veiculo Veiculo @relation(fields: [veiculoId], references: [id])

  @@map("item_venda")
}

// =========================================================================
// FINANCEIRO
// =========================================================================

model ContaBancaria {
  id          String   @id @default(cuid())
  tenantId    String
  nome        String   // apelido: "Conta Bradesco Principal"
  banco       String   // nome do banco
  codigoBanco String?  // código de compensação
  agencia     String?
  conta       String?
  // corrente | poupanca | pagamento | caixa_interno
  tipoConta   String   @default("corrente")
  pix         String?  // chave PIX
  ativo       Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  movimentacoes Movimentacao[]

  @@index([tenantId, ativo])
  @@map("conta_bancaria")
}

model CategoriaFinanceira {
  id        String        @id @default(cuid())
  tenantId  String
  nome      String
  tipo      TipoMovimento
  cor       String?       // hex color, ex: "#4ade80"
  icone     String?       // lucide icon name
  ativo     Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  tenant        Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  itens         ItemCategoriaFinanceira[]
  despesas      Despesa[]
  pagamentos    Pagamento[]
  movimentacoes Movimentacao[]

  @@unique([tenantId, nome])
  @@map("categoria_financeira")
}

model ItemCategoriaFinanceira {
  id          String   @id @default(cuid())
  categoriaId String
  nome        String
  ativo       Boolean  @default(true)
  createdAt   DateTime @default(now())

  categoria     CategoriaFinanceira @relation(fields: [categoriaId], references: [id], onDelete: Cascade)
  movimentacoes Movimentacao[]

  @@unique([categoriaId, nome])
  @@map("item_categoria_financeira")
}

model Movimentacao {
  id              String             @id @default(cuid())
  tenantId        String
  tipo            TipoMovimento      // ENTRADA / SAIDA
  status          StatusMovimentacao @default(PENDENTE)
  descricao       String
  valorCentavos   Int                // sempre positivo
  dataCompetencia DateTime           // data do fato gerador
  dataVencimento  DateTime?          // prazo de pagamento/recebimento
  dataPagamento   DateTime?          // quando foi efetivamente liquidado
  formaPagamento  FormaPagamento?
  categoriaId     String?
  itemId          String?
  contaBancariaId String?
  // Vínculos opcionais a entidades
  clienteId       String?
  fornecedorId    String?
  veiculoId       String?
  compraId        String?
  vendaId         String?
  observacoes     String?            @db.Text
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  tenant      Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  categoria   CategoriaFinanceira?     @relation(fields: [categoriaId], references: [id])
  item        ItemCategoriaFinanceira? @relation(fields: [itemId], references: [id])
  conta       ContaBancaria?           @relation(fields: [contaBancariaId], references: [id])
  cliente     ClienteFinal?            @relation(fields: [clienteId], references: [id])
  fornecedor  Fornecedor?              @relation(fields: [fornecedorId], references: [id])
  veiculo     Veiculo?                 @relation(fields: [veiculoId], references: [id])
  compra      Compra?                  @relation(fields: [compraId], references: [id])
  venda       Venda?                   @relation(fields: [vendaId], references: [id])
  anexos      AnexoMovimentacao[]

  @@index([tenantId, tipo, status])
  @@index([tenantId, dataCompetencia])
  @@index([tenantId, veiculoId])
  @@map("movimentacao")
}

model AnexoMovimentacao {
  id             String   @id @default(cuid())
  movimentacaoId String
  nome           String
  url            String
  storagePath    String
  mimeType       String
  tamanhoBytes   Int      @default(0)
  createdAt      DateTime @default(now())

  movimentacao Movimentacao @relation(fields: [movimentacaoId], references: [id], onDelete: Cascade)

  @@index([movimentacaoId])
  @@map("anexo_movimentacao")
}

// ─── Financeiro da própria plataforma (não é escopado por tenant) ───────────
// Espelha ContaBancaria/Movimentacao do tenant, mas para as finanças internas
// da AutoGestão (contas da empresa, despesas operacionais, outras receitas).
// Não entra nas políticas de RLS por tenantId (tabela sem tenantId).

model ContaBancariaPlataforma {
  id          String   @id @default(cuid())
  nome        String   // apelido: "Conta PJ Principal"
  banco       String
  codigoBanco String?
  agencia     String?
  conta       String?
  tipoConta   String   @default("corrente")
  pix         String?
  ativo       Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  movimentacoes MovimentacaoPlataforma[]
  recorrencias  MovimentacaoRecorrentePlataforma[]

  @@index([ativo])
  @@map("conta_bancaria_plataforma")
}

enum TipoEmissorFinanceiro {
  EMPRESA      // fornecedor / prestador de serviço PJ
  FUNCIONARIO  // folha de pagamento / colaborador
  SOCIO        // retirada de sócio (pró-labore / distribuição de lucros)
}

// Fornecedor, funcionário ou sócio associado a uma despesa/receita da plataforma.
model EmissorFinanceiroPlataforma {
  id          String                @id @default(cuid())
  nome        String
  tipo        TipoEmissorFinanceiro
  documento   String?               // CPF ou CNPJ
  contato     String?               // e-mail / telefone (texto livre)
  observacoes String?               @db.Text
  ativo       Boolean               @default(true)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  movimentacoes MovimentacaoPlataforma[]
  recorrencias  MovimentacaoRecorrentePlataforma[]

  @@index([ativo, tipo])
  @@map("emissor_financeiro_plataforma")
}

// Modelo (template) de despesa/receita recorrente mensal da plataforma.
// A cada mês, uma MovimentacaoPlataforma concreta é gerada a partir daqui
// (ver lib/financeiro-plataforma/recorrencias.ts) — o valor de cada mês
// gerado pode ser editado individualmente sem afetar o template nem os
// demais meses. Cancelar a recorrência (ativa = false) interrompe a
// geração de novos meses, mas preserva o histórico já gerado.
model MovimentacaoRecorrentePlataforma {
  id                  String          @id @default(cuid())
  tipo                TipoMovimento
  descricao           String
  categoria           String?
  valorPadraoCentavos Int
  diaVencimento       Int             @default(5) // dia do mês (1-28) em que a movimentação é gerada
  formaPagamento      FormaPagamento?
  contaBancariaId     String?
  emissorId           String?
  observacoes         String?         @db.Text
  ativa               Boolean         @default(true)
  dataInicio          DateTime        @default(now())
  dataFim             DateTime?       // preenchido automaticamente ao cancelar a recorrência
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  conta         ContaBancariaPlataforma?     @relation(fields: [contaBancariaId], references: [id])
  emissor       EmissorFinanceiroPlataforma? @relation(fields: [emissorId], references: [id])
  movimentacoes MovimentacaoPlataforma[]

  @@index([ativa])
  @@map("movimentacao_recorrente_plataforma")
}

model MovimentacaoPlataforma {
  id              String             @id @default(cuid())
  tipo            TipoMovimento      // ENTRADA (crédito) / SAIDA (débito)
  status          StatusMovimentacao @default(PENDENTE)
  descricao       String
  categoria       String?            // texto livre, ex: "Infraestrutura", "Assinaturas de tenants"
  valorCentavos   Int                // sempre positivo
  dataCompetencia DateTime
  dataVencimento  DateTime?
  dataPagamento   DateTime?
  formaPagamento  FormaPagamento?
  contaBancariaId String?
  emissorId       String?
  recorrenteId    String?            // preenchido quando gerada a partir de uma recorrência mensal
  observacoes     String?            @db.Text
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  conta       ContaBancariaPlataforma?          @relation(fields: [contaBancariaId], references: [id])
  emissor     EmissorFinanceiroPlataforma?      @relation(fields: [emissorId], references: [id])
  recorrencia MovimentacaoRecorrentePlataforma? @relation(fields: [recorrenteId], references: [id])

  @@index([tipo, status])
  @@index([dataCompetencia])
  @@index([recorrenteId])
  @@map("movimentacao_plataforma")
}

// ─── Configuração fiscal por tenant ──────────────────────────────────────────

model ConfiguracaoFiscal {
  id                    String   @id @default(cuid())
  tenantId              String   @unique
  regimeTributario      String   @default("simples")  // simples | lucro_presumido | lucro_real | mei
  aliquotaImpostosPct   Decimal  @default(6)    // % sobre receita bruta (Simples padrão)
  overheadMensalCentavos Int     @default(0)    // despesas fixas que não entram em categorias
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orcamentos OrcamentoMensal[]

  @@map("configuracao_fiscal")
}

// ─── Orçamento mensal (DRE Planejado) ────────────────────────────────────────

model OrcamentoMensal {
  id             String   @id @default(cuid())
  tenantId       String
  configFiscalId String?
  ano            Int
  mes            Int      // 1–12
  // JSON: { linhas: [{ tipo, descricao, categoriaId?, valorCentavos }] }
  receitasJson   Json     @default("[]")
  despesasJson   Json     @default("[]")
  // Substituições pontuais (null = usa o padrão da ConfiguracaoFiscal)
  aliquotaOverridesPct   Decimal?  // se null, usa ConfiguracaoFiscal.aliquotaImpostosPct
  overheadOverrideCentavos Int?    // se null, usa ConfiguracaoFiscal.overheadMensalCentavos
  observacoes    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant     Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  configFiscal ConfiguracaoFiscal? @relation(fields: [configFiscalId], references: [id])

  @@unique([tenantId, ano, mes])
  @@index([tenantId, ano, mes])
  @@map("orcamento_mensal")
}

model Despesa {
  id            String        @id @default(cuid())
  tenantId      String
  categoriaId   String?
  descricao     String
  valorCentavos Int
  vencimento    DateTime?
  status        StatusDespesa @default(ABERTA)
  anexoUrl      String?
  observacoes   String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  tenant     Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  categoria  CategoriaFinanceira? @relation(fields: [categoriaId], references: [id])
  pagamentos Pagamento[]

  @@index([tenantId, status])
  @@map("despesa")
}

model Pagamento {
  id             String         @id @default(cuid())
  tenantId       String
  tipo           TipoMovimento
  descricao      String
  valorCentavos  Int
  formaPagamento FormaPagamento @default(PIX)
  categoriaId    String?
  compraId       String?
  vendaId        String?
  despesaId      String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  tenant    Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  categoria CategoriaFinanceira? @relation(fields: [categoriaId], references: [id])
  compra    Compra?              @relation(fields: [compraId], references: [id])
  venda     Venda?               @relation(fields: [vendaId], references: [id])
  despesa   Despesa?             @relation(fields: [despesaId], references: [id])
  parcelas  Parcela[]

  @@index([tenantId, tipo])
  @@map("pagamento")
}

model Parcela {
  id            String        @id @default(cuid())
  pagamentoId   String
  numero        Int
  vencimento    DateTime
  valorCentavos Int
  pagoEm        DateTime?
  status        StatusParcela @default(ABERTA)

  pagamento Pagamento @relation(fields: [pagamentoId], references: [id], onDelete: Cascade)

  @@unique([pagamentoId, numero])
  @@map("parcela")
}

// =========================================================================
// DOCUMENTOS E ASSINATURAS
// =========================================================================

model ModeloDocumento {
  id            String   @id @default(cuid())
  tenantId      String
  nome          String
  descricao     String?
  conteudoHtml  String   @db.Text
  variaveisJson Json?
  versao        Int      @default(1)
  ativo         Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  documentos Documento[]

  @@unique([tenantId, nome, versao])
  @@map("modelo_documento")
}

model Documento {
  id           String   @id @default(cuid())
  tenantId     String
  modeloId     String?
  nome         String
  url          String
  mimeType     String?
  compraId     String?
  vendaId      String?
  metadataJson Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  modelo           ModeloDocumento?  @relation(fields: [modeloId], references: [id])
  compra           Compra?           @relation(fields: [compraId], references: [id])
  venda            Venda?            @relation(fields: [vendaId], references: [id])
