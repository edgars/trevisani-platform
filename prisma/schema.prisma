  tenantId  String
  usuarioId String?
  titulo    String
  corpo     String
  lidaEm    DateTime?
  meta      Json?
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, usuarioId])
  @@map("notificacao")
}

